# Lark Loom · 飞书测试环境变量
#
# 用法：
#   cp .env.example .env
#   按下面注释把 4 个值填进去（应用凭证 → 飞书开放平台 / 凭证与基础信息）

# 应用 App ID（cli_ 开头）
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx

# 应用 App Secret
LARK_APP_SECRET=

# Bot 自身 open_id，用于判断群消息是否 @ 了机器人
LARK_BOT_OPEN_ID=ou_xxxxxxxxxxxxxxxx

# 事件订阅 · Verification Token
LARK_VERIFICATION_TOKEN=

# 事件订阅 · Encrypt Key（开了加密才需要；没开就留空）
LARK_ENCRYPT_KEY=

# 日志级别（可选）：debug | info | warn | error
LARK_LOG_LEVEL=info

# 火山方舟 LLM（Doubao）
# API Key → 火山方舟控制台 / API Key 管理
ARK_API_KEY=

# 推理接入点 ID（ep- 开头）→ 火山方舟控制台 / 在线推理 / 创建推理接入点
ARK_MODEL_LITE=ep-xxxxxxxxxxxxxxxx-lite
ARK_MODEL_PRO=ep-xxxxxxxxxxxxxxxx-pro
